if (i == 19) {
current2 <- current1
}
# branch 2
if (i >= 20) {
df$b2[i] <- current2
current2 <- current2 + rnorm(1, mean=0, sd=0.2)
}
# making the next split
if (i == 49) {
current3 <- current1
}
# branch 2
if (i >= 50) {
df$b3[i] <- current3
current3 <- current3 + rnorm(1, mean=0, sd=0.2)
}
}
plot(x=df$timestep, y=df$b1, ylim = c(-5, 5),col="black", xlab="timesteps", ylab="trait value", type="line" )
lines(x=df$timestep, y=df$b2, col="red")
lines(x=df$timestep, y=df$b3, col="blue")

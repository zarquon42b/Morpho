setwd("/home/mario/Documents/teaching/MMA/macroevolution_ws25-26/practical_py_comp")
elopomorph_tree <- read.tree("elopomorph.tre")
elopomorph_data <- read.csv("elopomorph.csv")
elopomorph_tl_max <- elopomorph_data$Max_TL_cm
# Lets also make it a named vector
names(elopomorph_tl_max) <- elopomorph_data$X
elopomorph_log_tl_max <- log(elopomorph_tl_max)
elopomorph_log_tl_max_fitted_bm <- anc.ML(elopomorph_tree,
elopomorph_log_tl_max,
model = "BM",
maxit = 2000,
vars = TRUE,
CI=TRUE)
print(elopomorph_log_tl_max_fitted_bm$convergence)
print(elopomorph_log_tl_max_fitted_bm$logLik)
elopomorph_tree$tip.label
# Our tree has 61 tips
elopomorph_tree$Nnode
# and 60 (internal) nodes
elopomorph_log_tl_max_cont <- contMap(elopomorph_tree,
elopomorph_log_tl_max,
plot = FALSE,
lims = c(2.7, 5.8))
print(elopomorph_log_tl_max_cont)
elopomorph_log_tl_max_cont$tree
plot(elopomorph_log_tl_max_cont, fsize=0.5)
plot(elopomorph_log_tl_max_cont, fsize=0.7)
errorbar.contMap(elopomorph_log_tl_max_cont)
subtree_ancestor_index <- getMRCA(elopomorph_tree, c(3,14))
elopomorph_subtree <- extract.clade(elopomorph_tree, subtree_ancestor_index)
elopomorph_subtree_cont <- keep.tip.contMap(elopomorph_log_tl_max_cont, elopomorph_subtree$tip.label)
plot(elopomorph_subtree_cont)
errorbar.contMap(elopomorph_subtree_cont)

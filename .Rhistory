install.packages("plotly")
library(plotly)
# Example data
set.seed(1)
n <- 200
df <- data.frame(
x = rnorm(n),
y = rnorm(n),
z = rnorm(n),
group = factor(sample(letters[1:5], n, replace = TRUE))
)
# Choose 5 symbols and 5 colors
symbols <- c("circle", "square", "diamond", "cross", "triangle-up")
colors  <- RColorBrewer::brewer.pal(5, "Set1")
# Build plot with one trace per group
p <- plot_ly()
for (i in seq_along(levels(df$group))) {
g <- levels(df$group)[i]
sub <- df[df$group == g, ]
p <- add_trace(
p,
x = sub$x, y = sub$y, z = sub$z,
type = "scatter3d",
mode = "markers",
marker = list(
size = 5,
color = colors[i],
symbol = symbols[i]
),
name = g
)
}
p
